{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "lib": ["ESNext", "DOM"],
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "strict": false,
    "types": ["node", "@playwright/test"]
  },
  "include": ["**/*.ts", "types/**/*.d.ts"]
}